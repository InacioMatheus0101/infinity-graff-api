# =============================================
# INFINITY GRAFF API — Variáveis de Ambiente
# Fase 1: Fundação Segura e Escalável
# =============================================
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser versionado no Git.
# Este arquivo .env.example pode ser versionado, pois não contém segredos reais.
# =============================================

# ===== Banco de Dados (Supabase / PostgreSQL) =====
# Use a string JDBC do Session Pooler do Supabase.
DATABASE_URL=jdbc:postgresql://seu-host-pooler-supabase:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres.seu_project_ref
DATABASE_PASSWORD=sua_senha_do_banco_aqui

# ===== Supabase Auth =====
# Supabase Auth será responsável por cadastro, login, sessão e refresh token.
# O backend Spring validará o access token recebido no header Authorization.
SUPABASE_PROJECT_URL=https://seu-project-ref.supabase.co
SUPABASE_JWT_SECRET=seu_jwt_secret_do_supabase
SUPABASE_ISSUER=https://seu-project-ref.supabase.co/auth/v1
SUPABASE_AUDIENCE=authenticated

# ===== CORS =====
# Lista de origens permitidas separadas por vírgula.
# NUNCA usar * em produção.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ===== Ambiente da Aplicação =====
# Valores possíveis: development | staging | production
APP_ENV=development

# Profile do Spring.
# Usado para ativar beans com @Profile, como AdminSeeder em development.
SPRING_PROFILES_ACTIVE=development

# ===== Swagger / OpenAPI =====
# Em production deve ser false.
SWAGGER_ENABLED=true

# ===== Versão da Aplicação =====
APP_VERSION=1.0.0

# ===== Timezone =====
TZ=UTC

# ===== Admin Inicial =====
# Usado apenas pelo AdminSeeder quando SPRING_PROFILES_ACTIVE=development.
# Não use senha real no .env.example.
ADMIN_INITIAL_EMAIL=admin@infinitygraff.com
ADMIN_INITIAL_PASSWORD=senha_forte_apenas_para_desenvolvimento

# ===== Pool de Conexões =====
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000